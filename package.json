{
  "name": "react-flow-scrollbar",
  "version": "0.1.0",
  "description": "Custom, viewport-synced scrollbars and bounded panning (translateExtent) for React Flow / @xyflow/react v12.",
  "keywords": [
    "react-flow",
    "reactflow",
    "xyflow",
    "scrollbar",
    "scrollbars",
    "viewport",
    "pan",
    "translateExtent",
    "react",
    "diagram"
  ],
  "license": "MIT",
  "author": "Laststance.io",
  "homepage": "https://github.com/laststance/react-flow-scrollbar#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laststance/react-flow-scrollbar.git"
  },
  "bugs": {
    "url": "https://github.com/laststance/react-flow-scrollbar/issues"
  },
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "example:dev": "vite examples/playground",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "push-release-commit": "push-release-commit",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@xyflow/react": ">=12.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@laststance/npm-publish-tool": "^2.1.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.2",
    "@xyflow/react": "12.11.2",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "release-it": "^20.2.0",
    "tsup": "^8.3.5",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
